#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/install/install-lib.sh"
DRY_RUN="${DRY_RUN:-0}"
YES="${YES:-0}"

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --yes|-y) YES=1; shift ;;
    *) echo "Unknown arg: $1"; exit 2 ;;
  esac
done

require_cmds curl sudo gpg apt-get lsb_release
OS="$(detect_os)"
if [ "$OS" != "debian" ] && [ "$OS" != "linux" ]; then
  echo "This docker installer currently supports Debian/Ubuntu-like systems." >&2
  exit 1
fi

confirm_or_die "This will add Docker's apt repository and install docker-ce. Continue?"

run_cmd "sudo apt-get update && sudo apt-get install -y apt-transport-https ca-certificates curl gnupg lsb-release"

run_cmd "curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg"

run_cmd "echo \"deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable\" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null"

run_cmd "sudo apt-get update"
run_cmd "sudo apt-get install -y docker-ce docker-ce-cli containerd.io"

# safer permission handling: add user to docker group and inform to re-login
run_cmd "sudo usermod -aG docker "$USER""
if [ "${DRY_RUN:-0}" -eq 0 ]; then
  echo "Added $USER to docker group. Log out and log back in for group membership to take effect. Avoid using 'chmod 666 /var/run/docker.sock' — it's unsafe." 
fi

