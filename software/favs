#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/install/install-lib.sh"

DRY_RUN="${DRY_RUN:-0}"
YES="${YES:-0}"
GO_VERSION="${GO_VERSION:-1.23.3}"

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --yes|-y) YES=1; shift ;;
    --go) GO_VERSION="$2"; shift 2 ;;
    *) echo "Unknown arg: $1"; exit 2 ;;
  esac
done

require_cmds curl wget gpg lsb_release dpkg

# Detect OS (uses install-lib detect_os)
OS="$(detect_os)"
echo "Detected OS: $OS"

apt_update_done=0
apt_update() {
  if [ $apt_update_done -eq 0 ]; then
    run_cmd "sudo apt-get update"
    apt_update_done=1
  fi
}

apt_install_if_needed() {
  local pkg="$1"
  if dpkg -s "$pkg" >/dev/null 2>&1; then
    echo "Package $pkg already installed"
  else
    apt_update
    run_cmd "sudo apt-get install -y --no-install-recommends $pkg"
  fi
}

add_apt_keyring_repo() {
  local key_url="$1" keyfile="$2" sources_list="$3" repo_line="$4"
  if [ ! -f "$keyfile" ]; then
    run_cmd "sudo mkdir -p /etc/apt/keyrings"
    run_cmd "curl -fsSL '$key_url' | sudo gpg --dearmor -o '$keyfile'"
    run_cmd "sudo chmod a+r '$keyfile'"
  fi
  if [ ! -f "/etc/apt/sources.list.d/$sources_list" ]; then
    run_cmd "echo '$repo_line' | sudo tee /etc/apt/sources.list.d/$sources_list > /dev/null"
    apt_update
  fi
}

# VSCode
if command -v code >/dev/null 2>&1; then
  echo "VSCode already installed"
else
  echo "Installing VSCode"
  add_apt_keyring_repo "https://packages.microsoft.com/keys/microsoft.asc" "/etc/apt/keyrings/microsoft.gpg" "vscode.list" "deb [arch=amd64 signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/vscode stable main"
  apt_install_if_needed code
  verify_command code '^.' 'code --version' || true
fi

# sdkman
if [ -d "$HOME/.sdkman" ] || command -v sdk >/dev/null 2>&1; then
  echo "sdkman already installed"
else
  echo "Installing sdkman"
  apt_install_if_needed zip || true
  run_cmd "curl -s 'https://get.sdkman.io' | bash"
fi

# pnpm
if command -v pnpm >/dev/null 2>&1; then
  echo "pnpm already installed"
else
  echo "Installing pnpm"
  run_cmd "curl -fsSL https://get.pnpm.io/install.sh | sh -"
  verify_command pnpm '^[0-9]+' 'pnpm --version' || true
fi

# Node via nvm (LTS)
if command -v node >/dev/null 2>&1; then
  echo "node already installed: $(node --version)"
else
  echo "Installing Node LTS via nvm"
  # Install nvm if needed
  if [ ! -d "$HOME/.nvm" ] && ! command -v nvm >/dev/null 2>&1; then
    run_cmd "curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash"
  fi
  # Ensure nvm is available in this shell
  export NVM_DIR="$HOME/.nvm"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1091
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh"
  elif [ -s "$HOME/.nvm/nvm.sh" ]; then
    . "$HOME/.nvm/nvm.sh"
  else
    echo "nvm not found after install; please source your shell profile and re-run" >&2
  fi
  # Install LTS and set default
  run_cmd "nvm install --lts"
  run_cmd "nvm alias default 'lts/*' || true"
  verify_command node '^v[0-9]+' 'node --version' || true
fi

# GitHub CLI (gh)
if command -v gh >/dev/null 2>&1; then
  echo "gh already installed"
else
  echo "Installing GitHub CLI"
  add_apt_keyring_repo "https://cli.github.com/packages/githubcli-archive-keyring.gpg" "/etc/apt/keyrings/githubcli-archive-keyring.gpg" "github-cli.list" "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main"
  apt_install_if_needed gh
  verify_command gh '^[0-9]' 'gh --version' || true
fi

# Go
if command -v go >/dev/null 2>&1; then
  echo "go is present: $(go version)"
else
  echo "Installing Go"
  if [ "$OS" = "macos" ]; then
    # Homebrew path
    if ! command -v brew >/dev/null 2>&1; then
      echo "Homebrew not found; installing Homebrew"
      run_cmd '/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
    fi
    run_cmd "brew install go"
  else
    if [ -z "${GO_VERSION:-}" ] || [ "$GO_VERSION" = "latest" ]; then
      GO_VERSION="$(curl -sS https://go.dev/VERSION?m=text 2>/dev/null | sed 's/^go//')"
      echo "Resolved latest Go version: $GO_VERSION"
    fi
    local_tar="/tmp/go${GO_VERSION}.linux-amd64.tar.gz"
    run_cmd "wget -O '$local_tar' https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz"
    run_cmd "sudo rm -rf /usr/local/go && sudo tar -C /usr/local -xzf '$local_tar'"
    if ! grep -q '/usr/local/go/bin' <<< "$(cat \"$HOME\"/.bashrc 2>/dev/null || true)"; then
      run_cmd "echo 'export PATH=\\"\\$PATH:/usr/local/go/bin\\"' >> '$HOME/.bashrc'"
    fi
  fi
  # validate go
  verify_command go 'go[0-9]+' 'go version' || true
fi

# mods
if command -v mods >/dev/null 2>&1; then
  echo "mods already present"
else
  echo "Installing mods"
  run_cmd "sudo mkdir -p /etc/apt/keyrings"
  run_cmd "curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg"
  run_cmd "echo 'deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ *' | sudo tee /etc/apt/sources.list.d/charm.list"
  apt_install_if_needed mods || true
fi

# wezterm
if command -v wezterm >/dev/null 2>&1; then
  echo "wezterm already installed"
else
  echo "Installing wezterm"
  add_apt_keyring_repo "https://wezfurlong.org/wezterm/apt/wezterm.asc" "/etc/apt/keyrings/wezterm.gpg" "wezterm.list" "deb [signed-by=/etc/apt/keyrings/wezterm.gpg] https://wezfurlong.org/wezterm/apt/ $(lsb_release -cs) main"
  apt_install_if_needed wezterm || true
  verify_command wezterm '.*' 'wezterm --version' || true
fi

# chezmoi
if command -v chezmoi >/dev/null 2>&1; then
  echo "chezmoi already installed"
else
  echo "Installing chezmoi"
  run_cmd "sh -c \"\$(curl -fsLS get.chezmoi.io)\" -- -b /usr/local/bin"
  verify_command chezmoi 'chezmoi' 'chezmoi --version' || true
fi

# atuin
if command -v atuin >/dev/null 2>&1; then
  echo "atuin already installed"
else
  echo "Installing atuin"
  run_cmd "curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh"
  verify_command atuin '.*' 'atuin --version' || true
fi

# Google Chrome
if dpkg -s google-chrome-stable >/dev/null 2>&1 || command -v google-chrome-stable >/dev/null 2>&1 || command -v google-chrome >/dev/null 2>&1; then
  echo "Chrome already installed"
else
  echo "Installing Google Chrome"
  tmpdeb="/tmp/google-chrome-stable_current_amd64.deb"
  run_cmd "wget -O '$tmpdeb' https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"
  run_cmd "sudo apt-get install -y '$tmpdeb' || sudo apt-get install -f -y"
  run_cmd "rm -f '$tmpdeb'"
  # validate chrome install (binary may be google-chrome-stable or google-chrome)
  if command -v google-chrome-stable >/dev/null 2>&1; then
    verify_command google-chrome-stable '.*' 'google-chrome-stable --version' || true
  elif command -v google-chrome >/dev/null 2>&1; then
    verify_command google-chrome '.*' 'google-chrome --version' || true
  else
    echo "Warning: chrome binary not found after install"
  fi
fi

echo "favs install complete. Backups (if any) at ${BACKUP_DIR:-$HOME/.power-installer-backups}"
